# Public-safe session template for d05_c3_t1_l1_raw_fusion_upper_bound
# The target AP should be the primary prplOS-compatible dual-band AP node.
# This reference surface stages one local primary UART capture and one optional
# auxiliary command-backed capture for the helper node. Keep private helper-host
# addresses and credentials only in your local untracked session.env file.

CWSLAB_PUBLIC_OUTPUT_ROOT="/absolute/path/for/new/runtime-bundles"
CWSLAB_PUBLIC_AP_HOST="replace-with-ap-host"
CWSLAB_PUBLIC_AP_USER="root"
CWSLAB_PUBLIC_AP_PORT="22"
CWSLAB_PUBLIC_AP_RADIO_REF="Device.WiFi.Radio.2."
CWSLAB_PUBLIC_AP_SSID_REF="Device.WiFi.SSID.4."
CWSLAB_PUBLIC_AP_ACCESS_POINT_REF="Device.WiFi.AccessPoint.3."
CWSLAB_PUBLIC_AP_BRIDGE_INTERFACE="br-lan"
CWSLAB_PUBLIC_AP_CHANNEL="36"
CWSLAB_PUBLIC_AP_BANDWIDTH="20MHz"
CWSLAB_PUBLIC_AP_SSID="replace-with-public-safe-ssid"
CWSLAB_PUBLIC_AP_SECURITY_MODE="WPA2-Personal"
CWSLAB_PUBLIC_AP_KEY_PASSPHRASE="replace-with-non-public-passphrase"
CWSLAB_PUBLIC_SENSOR_DEVICE="/dev/<sensor-device>"
CWSLAB_PUBLIC_SENSOR_BAUD="115200"
CWSLAB_PUBLIC_SENSOR_PING_HOST="replace-with-sensor-host"
CWSLAB_PUBLIC_FIRMWARE_ROOT="/absolute/path/to/firmware/workspace"
CWSLAB_PUBLIC_FIRMWARE_ENV_SCRIPT="/absolute/path/to/export.sh"
CWSLAB_PUBLIC_FIRMWARE_TARGET="esp32c5"
CWSLAB_PUBLIC_FIRMWARE_TOOLS_PATH="/absolute/path/to/.espressif"

# Optional helper-node capture. The command should print the auxiliary raw stream
# to stdout, for example via an SSH wrapper that forwards UART from a helper host.
CWSLAB_PUBLIC_AUX_SENSOR_ID="esp32-c5-b"
CWSLAB_PUBLIC_AUX_SENSOR_COMMAND="/absolute/path/to/local/helper-node-capture-wrapper.sh"
CWSLAB_PUBLIC_AUX_SENSOR_OUTPUT="serial/esp32_c5_b_guided_session.log"

CWSLAB_PUBLIC_NOTIFY_SOUND_ENABLE="0"
CWSLAB_PUBLIC_NOTIFY_SOUND_FILE=""
